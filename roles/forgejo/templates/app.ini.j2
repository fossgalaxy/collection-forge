; {{ ansible_managed }}
;; see https://forgejo.org/docs/next/admin/config-cheat-sheet for additional documentation.
;; includes modifications in https://codeberg.org/forgejo/forgejo/src/branch/forgejo/docker/root/etc/templates/app.ini

APP_NAME = {{ forgejo_name }}
APP_SLOGAN = {{ forgejo_slogan }}

RUN_MODE = prod
RUN_USER = git
WORK_PATH = /data/gitea

[server]

; HTTP
PROTOCOL = http
DOMAIN = {{ forgejo_domain }}
HTTP_PORT = 3000

APP_DATA_PATH = {{ forgejo_dir_root }}
SSH_DOMAIN = {{ forgejo_ssh_domain }}
ROOT_URL = {{ forgejo_url }}
OFFLINE_MODE = true

; SSH
DISABLE_SSH = {% if forgejo_ssh_port %}false{% else %}true{% endif %}

SSH_PORT = {{ forgejo_ssh_port }}
SSH_LISTEN_PORT = 22

; LFS
LFS_START_SERVER = true
LFS_JWT_SECRET_URI = file:/run/secrets/{{ forgejo_secret_jwt_lfs }}

[database]
DB_TYPE = postgres
HOST = {{ forgejo_db_host }}
NAME = {{ forgejo_db_name }}
USER = {{ forgejo_db_user }}
PASSWD_URI = file:/run/secrets/{{ forgejo_secret_db_password }}
LOG_SQL = false

[indexer]
ISSUE_INDEXER_PATH = /data/gitea/indexers/issues.bleve

[session]
PROVIDER_CONFIG = /data/gitea/sessions
PROVIDER = file

# Storage Paths
[attachment]
PATH = {{ forgejo_dir_attachments }}

[avatar]
PATH = {{ forgejo_dir_avatars_user }}

[repo-avatar]
PATH = {{ forgejo_dir_avatars_repo }}

[repo-archive]
PATH = {{ forgejo_dir_repo_archive }}

[packages]
PATH = {{ forgejo_dir_packages }}

[storage.actions_log]
PATH = {{ forgejo_dir_actions_log }}

[actions.artifacts]
PATH = {{ forgejo_dir_actions_artefacts }}

[lfs]
PATH = {{ forgejo_dir_git_lfs }}

[log]
MODE = console
LEVEL = info
ROOT_PATH = /data/gitea/log

[security]
INSTALL_LOCK = true
SECRET_KEY_URI = file:/run/secrets/{{ forgejo_secret_secretkey }}
REVERSE_PROXY_LIMIT = 1
REVERSE_PROXY_TRUSTED_PROXIES = *
INTERNAL_TOKEN_URI = file:/run/secrets/{{ forgejo_secret_internal_token }}
PASSWORD_HASH_ALGO = pbkdf2_hi

[service]
DISABLE_REGISTRATION = true
REQUIRE_SIGNIN_VIEW  = false
REGISTER_EMAIL_CONFIRM = false
ENABLE_NOTIFY_MAIL = false
ALLOW_ONLY_EXTERNAL_REGISTRATION = false
ENABLE_CAPTCHA = false
DEFAULT_KEEP_EMAIL_PRIVATE = false
DEFAULT_ALLOW_CREATE_ORGANIZATION = true
DEFAULT_ENABLE_TIMETRACKING = true
NO_REPLY_ADDRESS = {{ forgejo_domain_noreply }}

[repository]
ROOT = {{ forgejo_dir_git_repos }}
{% if forgejo_licences_preferred %}
PREFERRED_LICENSES = {{ fg_forgejo_licences_preferred|join(',') }}
{% endif %}

[mailer]
ENABLED = false

[openid]
ENABLE_OPENID_SIGNIN = true
ENABLE_OPENID_SIGNUP = true

[cron.update_checker]
ENABLED = false

[repository.pull-request]
DEFAULT_MERGE_STYLE = merge

[repository.signing]
DEFAULT_TRUST_MODEL = committer

[oauth2]
JWT_SECRET_URI = file:/run/secrets/{{ forgejo_secret_jwt_oauth }}

[other]
SHOW_FOOTER_VERSION = false
SHOW_FOOTER_TEMPLATE_LOAD_TIME = false
